# Riku-Hub Environment Variables
# Copy this file to .dev.vars for local Wrangler development.
# Production secrets are set via: pnpm dlx wrangler secret put <KEY>

# ── Required ──────────────────────────────────────────────────────────────────

# Admin credentials (set as Wrangler secrets in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=<bcrypt-or-sha256-hash-of-your-password>

# Subscription token for /sub/:token endpoint
SUB_TOKEN=<random-32-char-string>

# Telegram image hosting (required for /riku/images feature)
TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>
TELEGRAM_CHAT_ID=<your-telegram-chat-id>

# ── KV / D1 Bindings (set in wrangler.toml, not here) ─────────────────────────
# CACHE_KV  — KV namespace for caches (favicon, DNS, aggregate output)
# DB        — D1 database for all structured data

# ── Optional ──────────────────────────────────────────────────────────────────

# Aggregate cache TTL in seconds (default: 3600)
# AGGREGATE_TTL_SECONDS=3600

# Maximum log entries to keep (default: 200)
# MAX_LOG_ENTRIES=200

# Enable public clipboard on login page (default: false)
# PUBLIC_CLIPBOARD_ENABLED=false

# ── Compat / Legacy (development/testing only) ────────────────────────────────

# Allow legacy /api/auth/register endpoint (MUST be false in production)
# COMPAT_ALLOW_REGISTER=false

# Register key required when COMPAT_ALLOW_REGISTER=true (min 32 chars)
# COMPAT_REGISTER_KEY=<random-32-char-string>
